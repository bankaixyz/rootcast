# Phase 2 environment for the World ID root replicator.
# Proof modes are `mock`, `cpu`, `cuda`, and `network`.
SP1_PROVER=network
NETWORK_PRIVATE_KEY=
EXECUTION_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_API_KEY
DATABASE_URL=sqlite://world-id-root-replicator.db
LISTEN_ADDR=127.0.0.1:3001
BANKAI_NETWORK=sepolia

BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
BASE_SEPOLIA_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

OP_SEPOLIA_RPC_URL=https://sepolia.optimism.io
OP_SEPOLIA_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
OP_SEPOLIA_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_SEPOLIA_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
ARBITRUM_SEPOLIA_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

STARKNET_SEPOLIA_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_9
STARKNET_SEPOLIA_ACCOUNT_ADDRESS=0xYOUR_STARKNET_ACCOUNT_ADDRESS
STARKNET_SEPOLIA_PRIVATE_KEY=0xYOUR_STARKNET_PRIVATE_KEY
STARKNET_SEPOLIA_REGISTRY_ADDRESS=0xYOUR_STARKNET_REGISTRY_ADDRESS

WORLD_ID_ROOT_REPLICATOR_PROGRAM_VKEY=0xYOUR_PROGRAM_VKEY
