# Phase 2 environment for the World ID root replicator.
# Proof modes are `mock`, `cpu`, `cuda`, and `network`.
#
# Frontend (Vite): set VITE_API_ORIGIN to the backend URL in production.
# In development, the Vite dev server proxies /api to LISTEN_ADDR automatically.
# VITE_API_ORIGIN=https://your-backend.example.com
SP1_PROVER=network
SP1_VERIFY_PROOF=true
NETWORK_PRIVATE_KEY=
EXECUTION_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_API_KEY
DATABASE_URL=sqlite://world-id-root-replicator.db
LISTEN_ADDR=127.0.0.1:3001
BANKAI_NETWORK=sepolia
ENABLED_DESTINATION_CHAINS=base-sepolia,op-sepolia,arbitrum-sepolia,monad-testnet
PROGRAM_VKEY=0xYOUR_PROGRAM_VKEY
# Explorer API keys used by `contracts/script/deploy_registry.sh --verify`.
# Monad and Plasma can also fall back to ETHERSCAN_API_KEY if you prefer.
ETHERSCAN_API_KEY=
MONADSCAN_API_KEY=
PLASMA_TESTNET_API_KEY=

BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
BASE_SEPOLIA_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY

OP_SEPOLIA_RPC_URL=https://sepolia.optimism.io
OP_SEPOLIA_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
OP_SEPOLIA_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY

ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_SEPOLIA_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
ARBITRUM_SEPOLIA_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY

CHIADO_RPC_URL=https://gnosis-chiado-rpc.publicnode.com
CHIADO_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
CHIADO_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY
# Required for Chiado deploys unless you pass --verifier or export SP1_VERIFIER_ADDRESS.
CHIADO_SP1_VERIFIER_ADDRESS=

MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_TESTNET_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
MONAD_TESTNET_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY
# Optional override for Monad deploys. Defaults to the pinned testnet verifier below.
MONAD_TESTNET_SP1_VERIFIER_ADDRESS=0x9e630e6A6BFbcF1b1c213552Aaea5469ff5C9664

HYPEREVM_TESTNET_RPC_URL=https://rpc.hyperliquid-testnet.xyz/evm
HYPEREVM_TESTNET_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
HYPEREVM_TESTNET_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY
HYPEREVM_TESTNET_SP1_VERIFIER_ADDRESS=0x9e630e6A6BFbcF1b1c213552Aaea5469ff5C9664

TEMPO_TESTNET_RPC_URL=https://rpc.moderato.tempo.xyz
TEMPO_TESTNET_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
TEMPO_TESTNET_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY
TEMPO_TESTNET_SP1_VERIFIER_ADDRESS=0x9e630e6A6BFbcF1b1c213552Aaea5469ff5C9664

MEGAETH_TESTNET_RPC_URL=https://carrot.megaeth.com/rpc
MEGAETH_TESTNET_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
MEGAETH_TESTNET_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY
MEGAETH_TESTNET_SP1_VERIFIER_ADDRESS=0x9e630e6A6BFbcF1b1c213552Aaea5469ff5C9664

PLASMA_TESTNET_RPC_URL=https://testnet-rpc.plasma.to
PLASMA_TESTNET_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
PLASMA_TESTNET_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY
PLASMA_TESTNET_SP1_VERIFIER_ADDRESS=0x9e630e6A6BFbcF1b1c213552Aaea5469ff5C9664

STARKNET_SEPOLIA_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_9
STARKNET_SEPOLIA_ACCOUNT_ADDRESS=0xYOUR_STARKNET_ACCOUNT_ADDRESS
STARKNET_SEPOLIA_PRIVATE_KEY=0xYOUR_STARKNET_PRIVATE_KEY
STARKNET_SEPOLIA_REGISTRY_ADDRESS=0xYOUR_STARKNET_REGISTRY_ADDRESS

SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
SOLANA_DEVNET_PRIVATE_KEY='[YOUR_SOLANA_KEYPAIR_BYTES]'
SOLANA_DEVNET_PROGRAM_ID=YOUR_SOLANA_PROGRAM_ID
